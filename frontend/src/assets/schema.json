{
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "The title of the scouting site. This will be displayed in the header and browser tab."
    },
    "year": {
      "type": "number",
      "description": "The year this scouting config is relevant for. Defaults to the current year if not provided."
    },
    "delimiter": {
      "type": "string",
      "description": "The delimiter to use when joining the form data"
    },
    "team_number": {
      "type": "number",
      "description": "The team number of the team using this form."
    },
    "floatingField": {
      "type": "object",
      "properties": {
        "show": {
          "type": "boolean",
          "description": "Whether or not to always show this value at the top of the screen. May be useful on small screens"
        },
        "codeValue": {
          "type": "string",
          "description": "Code of the form field to get this value from"
        }
      },
      "required": [
        "show",
        "codeValue"
      ],
      "additionalProperties": false,
      "description": "Optional floating text box at the tob of the screen to show things like the team number. May be useful on small screens"
    },
    "theme": {
      "type": "object",
      "properties": {
        "light": {
          "type": "object",
